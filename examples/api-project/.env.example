# ── Server ──────────────────────────────────────────────────────────────────
# Port the API server listens on
PORT=3000

# Node environment: development, test, or production
NODE_ENV=development

# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://localhost:5432/todos_dev

# Maximum number of connections in the pool
DATABASE_POOL_SIZE=10

# ── Authentication ────────────────────────────────────────────────────────────
# Secret used to sign JWT tokens
# IMPORTANT: Change this to a long random string in production
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-this-in-production

# How long access tokens are valid (e.g., 1h, 30m, 7d)
JWT_EXPIRY=1h

# ── Logging ───────────────────────────────────────────────────────────────────
# Log level: debug, info, warn, error
LOG_LEVEL=debug
